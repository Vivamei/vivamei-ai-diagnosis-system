# volcengine ：调用火山方舟 / 豆包视觉模型
LLM_PROVIDER=qwen

# =========================================================
# 阿里云百炼 / Qwen OpenAI 兼容接口
# =========================================================
DASHSCOPE_API_KEY=sk-ws-H.RPXERYR.w1LD.MEUCIDqNvETI2sjLaisph0Sq2C5bHKI-FORJOaF03e3vogJ2AiEA8EQ5xsKzvTmUYbUlOrMcwLn9PXd5kYKmHzA__ugB8nc
